# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # NEVER expose this in frontend

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── University Gate ──────────────────────────────────────────────────────────
ALLOWED_EMAIL_DOMAIN=maju.edu.pk
